# Example stack config for one unyt release fleet.
#
# Each release gets its OWN Pulumi stack:
#
#   pulumi stack init v0-7-0
#   # set the two secrets (cannot be copied between stacks - they are
#   # encrypted with the stack's own key):
#   pulumi config set --secret digitalocean:token   <do-token>
#   pulumi config set --secret heart:influx-token    <influx-token>
#   # set the rest (or copy the non-secret keys below into Pulumi.v0-7-0.yaml):
#   pulumi config set heart:project-name Holo
#   pulumi config set heart:release v0-7-0
#   pulumi up
#
# The InfluxDB bucket named by heart:influx-bucket must already exist in
# InfluxDB - this program does not create it.
#
# Anything left unset falls back to the defaults in defaults.yaml (shown as the
# values below). Only heart:release, heart:project-name, digitalocean:token and
# heart:influx-token are required.
config:
  # --- required ---
  heart:release: v0-7-0                 # namespaces every droplet name + a release:<x> tag
  heart:project-name: Holo              # DigitalOcean project to file resources under
  # digitalocean:token  -> set with `pulumi config set --secret digitalocean:token ...`
  # heart:influx-token  -> set with `pulumi config set --secret heart:influx-token ...`

  # --- versions (defaults shown) ---
  heart:holochain-version: holochain-0.6.1
  heart:holo-keyutil-version: v0.1.0

  # --- network identity (defaults = shared unyt infra) ---
  # Override these to give the release its own network. Note: DNA-level network
  # seed isolation is applied at .happ install time, not here.
  heart:bootstrap-url: https://hc-auth-iroh-unyt.holochain.org/
  heart:signal-url: http://not-used:1234
  heart:relay-url: https://iroh-relay-unyt.holochain.org
  heart:auth-server: https://hc-auth-iroh-unyt.holochain.org

  # --- metrics (per-release bucket recommended; must exist in InfluxDB) ---
  heart:influx-url: https://us-east-1-1.aws.cloud2.influxdata.com
  heart:influx-org: "711f755560a58686"
  heart:influx-bucket: unyt

  # --- fleet shape (defaults shown; bridging counts are capped at 1) ---
  heart:always-online-count: "1"
  heart:blockchain-bridging-count: "1"
  heart:unyt-bridging-count: "1"
  heart:hf-swapper-count: "1"
  heart:hash-explorer-count: "1"
  heart:always-online-size: s-2vcpu-4gb
  heart:bridging-size: s-4vcpu-8gb
  heart:hf-swapper-size: s-2vcpu-4gb
  heart:hash-explorer-size: s-2vcpu-4gb
